generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum PricingModel {
  FREE
  FREEMIUM
  PAID
  SUBSCRIPTION
  CONTACT
}

enum ToolStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  ARCHIVED
}

// ─── Auth.js models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  reviews        Review[]
  bookmarks      Bookmark[]
  submittedTools Tool[]     @relation("SubmittedTools")

  @@index([role])
  @@index([createdAt(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Directory models ────────────────────────────────────────────────────────

model Category {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String @db.Text

  tools Tool[]

  @@index([slug])
  @@index([name])
}

model Tag {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?  @db.Text
  metaTitle       String?  @db.VarChar(70)
  metaDescription String?  @db.VarChar(160)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tools ToolTag[]

  @@index([slug])
  @@index([name])
}

model Tool {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  logo             String?
  websiteUrl       String
  pricingUrl       String?
  twitterUrl       String?
  linkedinUrl      String?
  youtubeUrl       String?
  discordUrl       String?
  pricingModel     PricingModel @default(FREE)
  shortDescription String       @db.VarChar(300)
  fullDescription  String       @db.Text
  metaTitle        String?      @db.VarChar(70)
  metaDescription  String?      @db.VarChar(160)
  featured         Boolean      @default(false)
  featuredUntil    DateTime?
  verified         Boolean      @default(false)
  status           ToolStatus   @default(DRAFT)
  views            Int          @default(0)
  clicks           Int          @default(0)
  categoryId       String
  submittedById    String?
  submitterEmail   String?      @db.VarChar(255)
  rejectionReason  String?      @db.Text
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  submittedBy User?       @relation("SubmittedTools", fields: [submittedById], references: [id], onDelete: SetNull)
  images      ToolImage[]
  reviews     Review[]
  bookmarks   Bookmark[]
  tags        ToolTag[]

  @@index([slug])
  @@index([name])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([featuredUntil])
  @@index([verified])
  @@index([submittedById])
  @@index([status, featured])
  @@index([status, createdAt(sort: Desc)])
  @@index([categoryId, status])
  @@index([categoryId, status, createdAt(sort: Desc)])
  @@index([featured, featuredUntil])
  @@index([status, featured, createdAt(sort: Desc)])
  @@index([views(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model ToolTag {
  toolId    String
  tagId     String
  createdAt DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([toolId, tagId])
  @@index([toolId])
  @@index([tagId])
  @@index([tagId, toolId])
}

model ToolImage {
  id        String   @id @default(cuid())
  imageUrl  String
  altText   String?
  caption   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  toolId    String
  createdAt DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([toolId, sortOrder])
  @@index([toolId, isPrimary])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      @db.SmallInt
  content   String   @db.Text
  userId    String
  toolId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([toolId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt(sort: Desc)])
}

model Bookmark {
  userId    String
  toolId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([userId, toolId])
  @@index([userId])
  @@index([toolId])
  @@index([createdAt(sort: Desc)])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt(sort: Desc)])
}
